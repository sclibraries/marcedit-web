# .env.example — template for marcedit-web's systemd EnvironmentFile.
#
# Copy to .env and fill in production values:
#     cp .env.example .env && vi .env
#
# Format constraint: systemd EnvironmentFile= expects bare KEY=value
# lines. No `export`, no `${variable}` expansion, no shell features.
# This is NOT the same format as the bash-sourced .env in
# folio-report-explorer — be careful if cross-referencing.

# Production mode. When set to 1/true/yes, anonymous sessions are
# refused and every anonymous request is audited as a refusal.
# REQUIRED on libtools2.
MARCEDIT_WEB_PROD=1

# Comma-separated allowlist of eppns / Google emails that get the
# Code view in the Tasks editor. Anyone not listed sees only the
# form-builder.
MARCEDIT_WEB_ADMINS=

# Audit log (JSONL) directory. Must be writable by the marcedit user.
MARCEDIT_WEB_AUDIT_DIR=/var/www/html/marcedit-web/data/audit

# SQLite database path. Same writability requirement as the audit dir.
MARCEDIT_WEB_DB_PATH=/var/www/html/marcedit-web/data/marcedit.db

# Tasks file root (per-user task .py files are materialized here at
# render time). Must be writable by the marcedit user.
MARCEDIT_WEB_TASKS_ROOT=/var/www/html/marcedit-web/data/tasks

# Persisted uploads root (signed-in users' active .mrc files survive
# browser refresh). Must be writable by the marcedit user.
MARCEDIT_WEB_UPLOADS_ROOT=/var/www/html/marcedit-web/data/uploads

# Upload caps in bytes.
MARCEDIT_WEB_MAX_UPLOAD_BYTES=2147483648
MARCEDIT_WEB_MAX_DIFF_BYTES=2147483648
MARCEDIT_WEB_MAX_TASKSFILE_BYTES=1048576
MARCEDIT_WEB_MAX_SESSION_BYTES=4294967296

# Streamlit framework-level upload cap (MB). Per-feature caps above
# this are the actually-enforced limits.
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=2048
