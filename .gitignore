# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/
.venv/
venv/
.python-version

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Source archives (large; lifted via /tmp/marcedit-inspect/)
marc-diff.zip
marc-processing.zip

# Streamlit local state
.streamlit/secrets.toml

# Plan / scratch
/tmp/

# Playwright MCP session artifacts
.playwright-mcp/

# Worktree directories created by superpowers:using-git-worktrees
.claude/
.worktrees/

# Local-only agent workflow + internal planning artifacts. Ticket markdown
# is version-controlled so task scope and rollback checkpoints travel with
# commits; other agent scratch docs remain local-only.
/CLAUDE.md
/AGENTS.md
/.tickets/*
!/.tickets/*.md
/docs/superpowers/
/docs/application-overview.md

# Per-user task storage (lives at runtime; not version-controlled)
data/tasks/users/
data/tasks/shared/

# Runtime audit logs (JSONL, one file per UTC day)
data/audit/

# SQLite database (TASK-049) — runtime state, never version-controlled.
# Covers the main file + WAL/SHM side-files.
data/*.db
data/*.db-wal
data/*.db-shm

# Persisted uploads (TASK-051) — per-user MARC bytes that survive
# refresh. Runtime state; never committed.
data/uploads/

# Ad-hoc Playwright screenshots dropped at the project root by
# ``browser_take_screenshot`` during dev verification. Promote any
# you want kept into ``docs/`` explicitly.
/*.png
/*.jpg
/*.jpeg

# Production environment variables (systemd EnvironmentFile)
.env
