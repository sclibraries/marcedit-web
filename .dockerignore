.git
.gitignore
.dockerignore
__pycache__
*.pyc
.pytest_cache
.venv
venv
.DS_Store
docs/*
!docs/jobs.md
tests
marc-diff.zip
marc-processing.zip
README.md
.tickets
# Runtime state is mounted at /app/data. Only immutable bootstrap files belong
# in an image; local catalog records and SQLite state must never enter context.
data/*
!data/.gitkeep
!data/marc-rules.txt
*.png
*.jpg
*.jpeg

# Never let secrets enter the build context — they are provided at runtime via
# a mount or env, never baked into the image (TASK-069).
.streamlit/secrets.toml
.streamlit/secrets*.toml
.env
