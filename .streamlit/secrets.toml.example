# marcedit-web — Streamlit native OAuth template (TASK-047)
#
# Copy this file to `.streamlit/secrets.toml` and fill in real values
# from a Google Cloud OAuth client. The real `secrets.toml` is
# gitignored (see top-level `.gitignore`).
#
# # Google Cloud setup (one-time, per environment):
#
# 1. Cloud Console → APIs & Services → Credentials → Create
#    Credentials → OAuth client ID → Web application.
# 2. Add an authorized redirect URI matching `redirect_uri` below:
#      Local dev:   http://localhost:8501/oauth2callback
#      Staging:     https://your-host.example.edu/oauth2callback
# 3. Copy the generated client ID + secret into `[auth.google]`.
# 4. Generate `cookie_secret` with a strong random:
#      python -c 'import secrets; print(secrets.token_urlsafe(64))'
#    A fresh secret invalidates every existing session, which is the
#    intended behavior on rotation.
#
# # Identity precedence
#
# `marcedit_web.lib.identity.current_user()` resolves to (in order):
#   1. The signed-in Google email (`st.user.email`).
#   2. The Shibboleth `REMOTE_USER` HTTP header (prod reverse proxy).
#   3. The Shibboleth `eppn` HTTP header.
#   4. `"anonymous"`.
#
# OAuth and Shibboleth can coexist — if both are present, OAuth wins.
# That's intentional: an operator who's signed in via Google should
# be identified by their Google email, not the proxy header that
# happens to be passing through.
#
# # Admin allowlist
#
# `MARCEDIT_WEB_ADMINS` is still the source of truth for the Tasks-
# editor Code view. Put Google emails in it the same way you put
# Shibboleth eppns there.
#
#   MARCEDIT_WEB_ADMINS="alice@example.edu,bob@example.edu"

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
# Long random string — rotate to invalidate every session.
cookie_secret = "REPLACE-ME-with-token_urlsafe(64)-output"

[auth.google]
client_id = "REPLACE-ME.apps.googleusercontent.com"
client_secret = "REPLACE-ME"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
